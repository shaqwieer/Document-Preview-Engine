{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "OnlyOffice": {
    "ServerUrl": "http://onlyoffice:80",
    "PublicUrl": "http://localhost:8080",
    "JwtSecret": "set_via_environment_variable",
    "CallbackBaseUrl": "http://dotnet_api:80"
  },
  "Files": {
    "StoragePath": "/app/storage",
    "AllowedExtensions": [ ".pptx", ".ppt", ".docx", ".doc", ".xlsx", ".xls", ".pdf" ]
  },
  "Cors": {
    "AllowedOrigins": [ "http://localhost:3000" ]
  }
}
